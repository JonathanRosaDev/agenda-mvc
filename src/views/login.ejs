<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
    <div class="row">
        <div class="col-lg-2"></div>
        <div class="col-lg-8 my-3">
            <h1 class="text-center">Ciar conta ou Entrar</h1>
            <p class="text-center lead">Faça o login ou crie sua conta</p>
            <div class="messages">
                <%- include('includes/messages') %>
            </div>
            
            <div class="row">
                <div class="col-lg-6">
                    <h4>Faça seu cadastro</h4>
                    <p class="mb-3" style="min-height: 50px;">Se você ainda não tem conta, preencha o formulário abaixo:</p>
                    <form class="form-cadastro" action="/login/register" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label>Seu email</label>
                            <input type="email" class="form-control" name="email" >
                        </div>
                        <div class="form-group">
                            <label>Sua senha</label>
                            <input type="password" class="form-control" name="password" >
                        </div>
                        <button type="submit" class="btn btn-primary my-2">Criar minha conta</button>
                    </form>
                </div>

                <div class="col-lg-6">
                    <h4>Faça seu login</h4>
                    <p class="mb-3" style="min-height: 50px;">Se você já tem conta, faça login abaixo:</p>
                    <form class="form-login" action="/login/login" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label>Seu email</label>
                            <input type="email" class="form-control" name="email" >
                        </div>
                        <div class="form-group">
                            <label>Sua senha</label>
                            <input type="password" class="form-control" name="password" >
                        </div>
                        <button type="submit" class="btn btn-primary my-2">fazer login</button>
                    </form>
                </div>
            </div>

        </div>
        <div class="col-lg-2"></div>
    </div>
</div>

<%- include('includes/footer') %>
    